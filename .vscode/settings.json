{
  "cmake.generator": "Ninja",
  "cmake.configureEnvironment": {
    "CMAKE_EXPORT_COMPILE_COMMANDS": "on"
  },
  // ---- clangd (единственный движок IntelliSense) ----
  // query-driver: разрешает clangd опросить arm-none-eabi-g++ о реальных
  // системных инклюдах (libstdc++/newlib) и target
  "clangd.arguments": [
    "--query-driver=**/arm-none-eabi-*"
  ],
  // ---- C/C++ (cpptools): IntelliSense выключен, чтобы не дублировать clangd ----
  "C_Cpp.intelliSenseEngine": "disabled",
  "C_Cpp.autocompleteAddParentheses": true,
  "C_Cpp.errorSquiggles": "enabled",
  "C_Cpp.intelliSenseUpdateDelay": 2000,
  "C_Cpp.workspaceParsingPriority": "highest",
  "C_Cpp.intelliSenseMaxMemory": 6144,
  "C_Cpp.intelliSenseMaxCachedProcesses": 4,
  "C_Cpp.default.defines": [
    "__ARM_ARCH_7EM__=1",
    "__CORTEX_M7=1",
    "__THUMBEL__=1",
    "__ARMEL__=1"
  ],
  // Suppress false positive template errors
  "C_Cpp.errorSquiggles": "enabled",
  "C_Cpp.dimInactiveRegions": false,
  // ---- Cortex Debug ----
  "cortex-debug.gdbPath": "arm-none-eabi-gdb",
  "cortex-debug.liveWatchRefreshRate": 500,
  // ---- IntelliSense / автокомплит ----
  "editor.quickSuggestions": {
    "other": true,
    "comments": true,
    "strings": true
  },
  "editor.suggestOnTriggerCharacters": true,
  "editor.acceptSuggestionOnEnter": "on",
  "editor.tabCompletion": "on",
  "editor.parameterHints.enabled": true,
  "editor.suggestSelection": "first",
  "editor.wordBasedSuggestions": "off",
  // ---- Автоматическая активация подсказок ----
  "editor.inlineSuggest.enabled": true,
  "editor.snippetSuggestions": "inline",
  "editor.suggest.showSnippets": true,
  "editor.acceptSuggestionOnCommitCharacter": true,
  // ---- Ассоциации файлов ----
  "files.associations": {
    "bit": "cpp",
    "cmath": "cpp",
    "compare": "cpp",
    "concepts": "cpp",
    "cstdarg": "cpp",
    "cstddef": "cpp",
    "cstdint": "cpp",
    "cstdio": "cpp",
    "cstdlib": "cpp",
    "cstring": "cpp",
    "type_traits": "cpp",
    "utility": "cpp",
    "initializer_list": "cpp",
    "limits": "cpp",
    "new": "cpp",
    "typeinfo": "cpp",
    "*.h": "cpp"
  },
  "C_Cpp.clang_format_path": "${workspaceFolder}/.clang-format",
  "C_Cpp.formatting": "vcFormat",
  "cortex-debug.variableUseNaturalFormat": false
}